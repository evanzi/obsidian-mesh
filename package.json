{
  "name": "obsidian-mesh",
  "version": "0.1.0",
  "description": "Sync your contacts from Mesh (me.sh) into Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "mesh", "contacts", "crm", "sync"],
  "author": "Evan Zimmerman",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "classic-level": "^2.0.0"
  }
}
